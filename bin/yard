#!/usr/bin/env bash
# yard — Subyard host CLI: a thin dispatcher over scripts/ (resolves the repo from
# its own path, so it works via a symlink on PATH).
set -euo pipefail

SELF="$(readlink -f "${BASH_SOURCE[0]:-$0}")"
REPO="$(cd "$(dirname "$SELF")/.." && pwd)"
S="$REPO/scripts"
export YARD_VERSION="0.1.0-dev"
PROG="${0##*/}"

# Host paths live in config/host.env (the single source). Source it best-effort — it is
# plain assignments with no deps, so `yard --help`/`--list` still work if it is missing.
# shellcheck disable=SC1091
[ -r "$REPO/config/host.env" ] && . "$REPO/config/host.env" 2>/dev/null || true

# The profile shared-resource REGISTRY (pure bash, no deps): lets `yard` discover, dispatch and
# list profile-provided in-yard services (emu/staging/qa-pool/…) from descriptor files
# (config/profiles/*/resources/*.res) WITHOUT hardcoding any of them here.
# shellcheck source=scripts/lib-resources.sh
[ -r "$S/lib-resources.sh" ] && . "$S/lib-resources.sh" 2>/dev/null || true

# Core command names (yard lifecycle / project workflow / project-env L2). Profile-resource
# commands are appended from the registry below, so adding a resource needs no edit here. Drives
# `yard --list` and both completions.
COMMANDS=(check init start status logs usage shell provision stop teardown sync bind clone list code export remove up down info yards remote)
if command -v res_commands >/dev/null 2>&1; then
  while IFS= read -r _rc; do [ -n "$_rc" ] && COMMANDS+=("$_rc"); done < <(res_commands 2>/dev/null)
fi

# where=host|yard for the audit line: explicit SUBYARD_SIDE wins, else detect the yard's container.
yard_side() {
  case "${SUBYARD_SIDE:-}" in host | yard) printf '%s' "$SUBYARD_SIDE"; return 0 ;; esac
  local v=none
  if command -v systemd-detect-virt >/dev/null 2>&1; then
    v="$(systemd-detect-virt -c 2>/dev/null || echo none)"
  fi
  if [ -n "$v" ] && [ "$v" != none ]; then printf yard; else printf host; fi
  return 0
}

# Best-effort audit log, one line per invocation; the dispatcher is the only writer. Masks URL
# creds and the payload after a standalone `--`. SUBYARD_NO_AUDIT=1 opts out; SUBYARD_AUDIT_MAX_BYTES
# (default 1 MiB) caps size, rotating once to yard.log.1.
audit() {
  [ -n "${SUBYARD_NO_AUDIT:-}" ] && return 0
  local dir="${SUBYARD_HOME:-$HOME/.subyard}/logs"
  install -d -m 700 "$dir" 2>/dev/null || return 0
  local log="$dir/yard.log" max="${SUBYARD_AUDIT_MAX_BYTES:-1048576}" sz side msg
  sz="$(stat -c%s "$log" 2>/dev/null || echo 0)"
  [ "${sz:-0}" -ge "$max" ] 2>/dev/null && mv -f "$log" "$log.1" 2>/dev/null || true
  side="$(yard_side)" || side=host
  # Append ` yard=<name>` for a named context; absent for the default yard (format unchanged).
  local yardf=''
  case "${SUBYARD_YARD:-}" in '' | default) ;; *) yardf=" yard=$SUBYARD_YARD" ;; esac
  # Remote context: note the owner host the command forwards to.
  local remotef=''
  [ -n "${REMOTE_DEST:-}" ] && remotef=" remote=$REMOTE_DEST"
  # mask URL creds (keep user), then drop the payload after a standalone `--`
  msg="$(printf '%s' "$*" | sed -E 's#(://[^/:@ ]+:)[^/@ ]*@#\1***@#g; s#(://)[^/:@ ]+@#\1***@#g; s/(^| )-- .*/\1-- ***/')" || msg="$*"
  printf '%s pid=%s cwd=%s where=%s%s%s -- %s\n' \
    "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$$" "$PWD" "$side" "$yardf" "$remotef" "$msg" >>"$log" 2>/dev/null || true
}

version() { printf '%s %s\n' "$PROG" "$YARD_VERSION"; }

list_commands() { printf '%s\n' "${COMMANDS[@]}"; }

usage() {
  cat <<U
$PROG $YARD_VERSION — a local yard for isolated project environments.

Usage: $PROG [option] <command> [args]

Yard lifecycle:
  check           verify the host can run a yard (read-only preflight)
  init            install everything: Incus -> project -> yard -> mounts -> provision
                  (--configs: refresh agent instructions/configs only;
                   --reset: teardown + fresh init; force-apply other config drift)
  start           start the yard
  status          read-only overview (yard + ssh + mounts + services + projects) and the
                  yard's size (cached, refreshed in the background when >10 min old)
  logs            tail the yard's runtime logs (systemd journal + docker)
  usage [args]    show coding-agent token usage
  shell  [proj]   shell in the yard as dev, optionally in a project's directory
         [--root] use root instead of dev; add \`-- <cmd>\` to run a command
  provision [prof] install a profile's toolchain INTO the yard (L1) so agents work
                  directly in the yard (P1 baseline); no arg = all in-yard profiles. Heavy/explicit.
  stop            stop the yard
  teardown        tear down the yard + free disk (--keep-data preserves /srv); keeps Incus
  yards           list all yards (name, type, instance, state, ssh, projects, size)

Project workflow (default path '.'):
  sync   [path]   copy a project into the yard (host -> yard; --target yard|<profile>)
  bind   [path]   mount a project from the host into the yard (shared files)
  clone  <url>    clone a repo straight into the yard
  list            list projects currently in the yard
  code   [path|name] open a project in VS Code by path or \`yard list\` name (Remote-SSH)
  export [path]   pull a diff/patch from the yard back to the host (sync projects)
  remove [path]   take a project out of the yard, deleting its copy (--soft keeps it)

Project-env (L2 box; for a project added with --target <profile>):
  up     [path]   build/start the project's box (--rebuild to rebuild the image)
  down   [path]   stop the box (keeps it)
  info   [path]   show what the profile exposes inside the box (visibility manifest)
                  (open a project shell with \`yard shell <project>\`; use \`yard code\` for VS Code)
U
  usage_resources
  cat <<U

  (init runs the phases in scripts/00-05; run those directly only for debugging.)

Named yards:
  Run several independent yards on one host, each with its own instance, /srv, ssh port,
  personal-data mount root and projects. Pick one for a command with -Y/--yard (or the
  sugar '@<name>' as the first token); no selection = the default yard, unchanged. Define a
  yard in private/yards/<name>.env or ~/.config/subyard/yards/<name>.env (SSH_PORT required).
  '$PROG yards' lists them all.

Remote yards:
  Drive a yard on ANOTHER host as if it were local. '$PROG remote add <name> <user@host>'
  probes it, registers a context, wires a collision-free ProxyJump ssh identity, authorizes
  your key and verifies the complete data plane before reporting it ready.
  Then '$PROG -Y <name> <cmd>': lifecycle commands (start/stop/status/provision/logs/shell/…)
  forward over ssh to the owner host with their native prompts; data-plane commands
  (code/sync/export/clone/remove) go straight into the yard. 'bind' is host-local and
  disabled for remote yards. Keys and secrets stay on the owner host.
  A real in-yard host-key change stays blocked. Verify its fingerprint on the trusted owner
  host, then use 'remote repair-key <name>' for an explicit, context-scoped rotation.
  Subcommands:  remote add <name> <user@host> [--yard <remote-yard>] | remote repair-key <name> | remote remove <name> | remote list

Options:
  -Y, --yard <name>  run the command against a named yard ('@<name>' first-token sugar)
  -h, --help      show this help and exit
  -l, --list      list command names (one per line) and exit
      --resources list profile-resource commands + verbs (tab-separated) and exit
  -V, --version   show version and exit
  -y, --yes       skip a command's confirmation prompt (pass-through)

Run '$PROG <command> -h' for a command's own help.
U
}

# Generated "Profile resources" section — long-lived in-yard services a profile exposes (emu /
# staging / qa-pool / …), read from the registry so usage() never enumerates them by hand. Each
# resource's own \`yard <cmd> -h\` carries its detailed help. No-op if the registry is unavailable.
usage_resources() {
  local rows; rows="$(res_rows 2>/dev/null)" || return 0
  [ -n "$rows" ] || return 0
  printf '\nProfile resources (long-lived in-yard services; run '\''%s <cmd> -h'\'' for each):\n' "$PROG"
  local p n c h b s v t
  while IFS=$'\t' read -r p n c h b s v t; do
    [ -n "$c" ] || continue
    printf '  %-9s %s\n' "$c" "$t"
    printf '            verbs: %s\n' "$v"
  done <<EOF
$rows
EOF
}

# --- yard context selection (global, before the command) ---------------------
# Pick a named yard: -Y/--yard <name>, --yard=<name>, or the sugar `@<name>` as the first token.
# Only leading occurrences (before the command) are consumed. Exported so lib.sh (load_config)
# sources that yard's env layer FIRST. No selection keeps the inherited SUBYARD_YARD (today's
# path). SUBYARD_YARD_EXPLICIT marks a flag/@ selection (vs. a session env) for cross-yard resolution.
SUBYARD_YARD="${SUBYARD_YARD:-}"
while [ $# -gt 0 ]; do
  case "$1" in
    -Y | --yard)
      if [ $# -ge 2 ]; then SUBYARD_YARD="$2"; SUBYARD_YARD_EXPLICIT=1; shift 2
      else printf "%s: unknown option '%s'\nTry '%s --help'.\n" "$PROG" "$1" "$PROG" >&2; exit 2; fi ;;
    --yard=*) SUBYARD_YARD="${1#--yard=}"; SUBYARD_YARD_EXPLICIT=1; shift ;;
    @?*)      SUBYARD_YARD="${1#@}";       SUBYARD_YARD_EXPLICIT=1; shift ;;
    *) break ;;
  esac
done
export SUBYARD_YARD
[ -n "${SUBYARD_YARD_EXPLICIT:-}" ] && export SUBYARD_YARD_EXPLICIT

# --- remote-context peek -----------------------------------------------------
# A REMOTE yard's control-plane commands forward over ssh to the owner host instead of a
# (non-existent) local instance. Targeted-parse the env file for three keys rather than source
# lib.sh (no config layers, no incus). REMOTE_DEST stays empty for the default and LOCAL yards,
# so the remote path below is inert unless a remote context is selected.
REMOTE_DEST=''; REMOTE_YARD=''
_yard_env_val() { # <file> <KEY> -> value (last `KEY=value` line wins, surrounding quotes stripped)
  # Deliberate twin of scripts/lib.sh:yard_env_val, so this peek needs no lib.sh. Keep in sync.
  sed -n "s/^[[:space:]]*$2=//p" "$1" 2>/dev/null | tail -n1 | sed -e 's/^"//' -e 's/"$//' -e "s/^'//" -e "s/'\$//"
}
_yard_remote_peek() {
  case "${SUBYARD_YARD:-}" in '' | default) return 0 ;; esac
  local name="$SUBYARD_YARD" ch dir f=''
  ch="${SUBYARD_CONFIG_HOME:-${SUBYARD_OPERATOR_HOME:-$HOME}/.config/subyard}"
  for dir in "$REPO/private/yards" "$ch/yards"; do
    [ -r "$dir/$name.env" ] && { f="$dir/$name.env"; break; }
  done
  [ -n "$f" ] || return 0
  [ "$(_yard_env_val "$f" YARD_TYPE)" = remote ] || return 0
  REMOTE_DEST="$(_yard_env_val "$f" REMOTE_DEST)"
  REMOTE_YARD="$(_yard_env_val "$f" REMOTE_YARD)"
}
_yard_remote_peek

# --- global options / no command ---------------------------------------------
case "${1:-}" in
  ''            ) usage; exit 0 ;;
  -h | --help   ) usage; exit 0 ;;
  -l | --list   ) list_commands; exit 0 ;;
  --resources   ) command -v res_completion_rows >/dev/null 2>&1 && res_completion_rows 2>/dev/null; exit 0 ;;
  -V | --version) version; exit 0 ;;
  -*            ) printf "%s: unknown option '%s'\nTry '%s --help'.\n" "$PROG" "$1" "$PROG" >&2; exit 2 ;;
esac

cmd="$1"; shift
# _info is a silent machine-readable probe (remote yards poll it) — keep it out of the audit log.
case "$cmd" in _info) ;; *) audit "$cmd" "$@" ;; esac

# Commands talk to incusd via the scripts, which call lib.sh's incus_preflight for an
# accurate message if the daemon is unreachable (e.g. a session that predates the
# incus-admin group → log back in). `yard init` self-continues across that group grant
# during install (scripts/init.sh); we do NOT silently re-wrap every command under `sg`.

# Reserved but not wired yet. Friendlier than "unknown command".
soon() { printf "%s: '%s' is planned for %s — not implemented yet.\n" "$PROG" "$1" "$2" >&2; exit 2; }

# --- remote-context routing --------------------------------------------------
# For a REMOTE yard, split commands by plane:
#   • control plane  → FORWARD to the owner host over `ssh -t` (tty preserved) so its OWN yard
#     runs the command with its native `Proceed? [y/N]` prompts intact; any -y/--yes rides along.
#   • data plane + registry ops (code sync export clone remove list check yards remote _info,
#     help) run LOCALLY — reaching the yard through the 'yard-<name>' ssh alias, or pure bookkeeping.
#   • bind is host-local: the host path does not exist on the remote machine → hard refusal.
# Two-level %q quoting so a token survives BOTH the remote login shell and the inner `bash -lc`.
# exec: this process becomes ssh, so its exit status is the remote command's.
remote_forward() {   # <cmd> <args…>
  local rc='yard' a repair_hint
  [ -n "$REMOTE_YARD" ] && rc="$rc -Y $(printf '%q' "$REMOTE_YARD")"
  for a in "$@"; do rc="$rc $(printf '%q' "$a")"; done
  if [ "${1:-}" = usage ]; then
    repair_hint="yard -Y $SUBYARD_YARD init"
    rc="SUBYARD_USAGE_REPAIR_HINT=$(printf '%q' "$repair_hint") $rc"
  fi
  exec ssh -t "$REMOTE_DEST" -- bash -lc "$(printf '%q' "$rc")"
}
if [ -n "$REMOTE_DEST" ]; then
  case "$cmd" in
    bind) printf 'bind is host-local — use sync or clone\n' >&2; exit 1 ;;
    code | sync | export | clone | remove | list | check | yards | remote | _info | help) ;; # local, fall through
    *) remote_forward "$cmd" "$@" ;;   # forward lifecycle / project-env / resource commands
  esac
fi

case "$cmd" in
  init | setup) exec "$S/init.sh" "$@" ;;            # setup: back-compat alias
  teardown | uninstall) exec "$S/99-teardown.sh" "$@" ;;  # uninstall: back-compat alias
  check)     exec "$S/00-check-host.sh" "$@" ;;
  sync)      exec "$S/project-sync.sh" sync "$@" ;;
  bind)      exec "$S/project-sync.sh" bind "$@" ;;
  list)      exec "$S/project-list.sh" "$@" ;;
  yards)     exec "$S/yard-yards.sh" "$@" ;;
  remote)    exec "$S/yard-remote.sh" "$@" ;;                 # manage remote yards (add/remove/list)
  _info)     exec "$S/yard-info.sh" "$@" ;;   # machine-readable probe (hidden; used by remote yards)
  _authorize) exec "$S/yard-authorize.sh" "$@" ;;  # hidden: authorize a controller key IN the yard (remote add)
  logs)      exec "$S/yard-logs.sh" "$@" ;;
  usage)     exec "$S/yard-usage.sh" "$@" ;;
  start | stop | status) exec "$S/yard-ctl.sh" "$cmd" "$@" ;;
  code)      exec "$S/project-code.sh" "$@" ;;
  remove)    exec "$S/project-remove.sh" "$@" ;;
  export)    exec "$S/project-export.sh" "$@" ;;
  up | down | info) exec "$S/project-env.sh" "$cmd" "$@" ;;   # L2 project-env box lifecycle
  provision) exec "$S/10-provision-profile.sh" "$@" ;;
  shell)     exec "$S/yard-shell.sh" "$@" ;;
  clone)     exec "$S/project-clone.sh" "$@" ;;
  help)      usage ;;
  # Profile-resource dispatch (emu/staging/qa-pool/…): `yard svc <name|cmd> <verb>` is the generic
  # entry; a bare resource command is also accepted. Both resolve via the registry, so no resource
  # is named here.
  svc | resource)
    rn="${1:-}"; shift || true
    [ -n "$rn" ] || { printf "%s: 'svc' needs a resource name or command (see '%s --resources')\n" "$PROG" "$PROG" >&2; exit 2; }
    rh="$(command -v res_handler_for >/dev/null 2>&1 && res_handler_for "$rn" 2>/dev/null || true)"
    [ -n "$rh" ] && [ -x "$S/$rh" ] || { printf "%s: unknown resource '%s' (see '%s --resources')\n" "$PROG" "$rn" "$PROG" >&2; exit 2; }
    exec "$S/$rh" "$@" ;;
  *)
    rh="$(command -v res_handler_for_command >/dev/null 2>&1 && res_handler_for_command "$cmd" 2>/dev/null || true)"
    if [ -n "$rh" ] && [ -x "$S/$rh" ]; then exec "$S/$rh" "$@"; fi
    printf "%s: unknown command '%s'\nTry '%s --help'.\n" "$PROG" "$cmd" "$PROG" >&2; exit 2 ;;
esac
