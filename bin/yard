#!/usr/bin/env bash
# yard — Subyard host CLI: a thin dispatcher over scripts/ (resolves the repo from
# its own path, so it works via a symlink on PATH).
set -euo pipefail

SELF="$(readlink -f "${BASH_SOURCE[0]:-$0}")"
REPO="$(cd "$(dirname "$SELF")/.." && pwd)"
S="$REPO/scripts"
YARD_VERSION="0.1.0-dev"
PROG="${0##*/}"

# Command names, in order, for --help and --list.
COMMANDS=(setup check import sync export remove clone code list status up down)

version() { printf '%s %s\n' "$PROG" "$YARD_VERSION"; }

list_commands() { printf '%s\n' "${COMMANDS[@]}"; }

usage() {
  cat <<U
$PROG $YARD_VERSION — a local yard for isolated agent machines.

Usage: $PROG [option] <command> [args]

Bring-up (says what it will do and asks first; root steps self-elevate):
  setup        install everything: Incus → project → yard → mounts → provision  [alias: init]
  check        verify the host can run a yard (read-only preflight)

  (setup runs the phases in scripts/00-05; run those directly only for debugging.)

Project commands (code projects in the yard; default path '.'):
  import [path]   bring a project into the yard (sync default; --bind opt-in)
  sync   [path]   resync a sync-project (host → yard)
  export [path]   pull a diff/patch from the yard back to the host
  remove [path]   take a project out of the yard (--purge also deletes the copy)
  clone  <url>    clone a repo straight into the yard
  code   [path]   open the project in VS Code (Remote-SSH → Reopen in Container)
  list            list projects currently in the yard
  status          read-only overview (yard + projects + agents)
  up | down       start / stop the yard

Options:
  -h, --help      show this help and exit
  -l, --list      list command names (one per line) and exit
  -V, --version   show version and exit
  -y, --yes       skip a command's confirmation prompt (pass-through)

Run '$PROG <command> -h' once subcommand help lands.
U
}

# --- global options / no command ---------------------------------------------
case "${1:-}" in
  ''            ) usage; exit 0 ;;
  -h | --help   ) usage; exit 0 ;;
  -l | --list   ) list_commands; exit 0 ;;
  -V | --version) version; exit 0 ;;
  -*            ) printf "%s: unknown option '%s'\nTry '%s --help'.\n" "$PROG" "$1" "$PROG" >&2; exit 2 ;;
esac

cmd="$1"; shift

# Reserved but not wired yet (Phase 7b). Friendlier than "unknown command".
soon() { printf "%s: '%s' is planned for %s — not implemented yet.\n" "$PROG" "$1" "$2" >&2; exit 2; }

case "$cmd" in
  setup | init) exec "$S/setup.sh" "$@" ;;
  check)     exec "$S/00-check-host.sh" "$@" ;;
  import | sync | export | remove | clone | code | list | status) soon "$cmd" "Phase 7b (project ingestion)" ;;
  up | down) soon "$cmd" "Phase 2/7 (yard lifecycle)" ;;
  help)      usage ;;
  *) printf "%s: unknown command '%s'\nTry '%s --help'.\n" "$PROG" "$cmd" "$PROG" >&2; exit 2 ;;
esac
