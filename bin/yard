#!/usr/bin/env bash
# Stable source-tree launcher for the checked-in native Go control-plane engine.
set -euo pipefail

SELF="$(readlink -f "${BASH_SOURCE[0]:-$0}")"
REPO="$(cd "$(dirname "$SELF")/.." && pwd)"
ENGINE="$REPO/bin/yard-engine"
PROG="${0##*/}"

[ -x "$ENGINE" ] || {
  printf '%s: checked-in native engine is unavailable at %s\n' "$PROG" "$ENGINE" >&2
  exit 2
}
case "$(uname -s)/$(uname -m)" in
  Linux/x86_64) ;;
  *)
    printf '%s: the checked-in bootstrap engine supports linux/amd64 only\n' "$PROG" >&2
    exit 2
    ;;
esac

export SUBYARD_REPOSITORY_ROOT="$REPO"
exec -a "$PROG" "$ENGINE" "$@"
