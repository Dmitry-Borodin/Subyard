#!/usr/bin/env bash
# Source-tree launcher for the native Go control-plane engine.
set -euo pipefail

SELF="$(readlink -f "${BASH_SOURCE[0]:-$0}")"
REPO="$(cd "$(dirname "$SELF")/.." && pwd)"
ENGINE="$REPO/.build/yard"
PROG="${0##*/}"

# The build helper is a no-op while the artifact is current. A packaged install
# links directly to bin/yard-engine and never downloads a toolchain at runtime.
"$REPO/scripts/build-engine.sh"
[ -x "$ENGINE" ] || {
  printf '%s: native engine is unavailable at %s\n' "$PROG" "$ENGINE" >&2
  exit 2
}

export SUBYARD_REPOSITORY_ROOT="$REPO"
exec -a "$PROG" "$ENGINE" "$@"
