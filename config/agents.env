# config/agents.env — the per-coding-agent layer.
#
# One stanza per agent: what default config to lay into the yard, and which session/state
# paths to persist on the host store so they survive a yard reset. Sourced by load_config
# (scripts/lib.sh) AFTER host.env (so it can use SUBYARD_CONFIG_DIR and the /mnt/host mount
# paths) and BEFORE the private overlay — so private/config.env can override any AGENT_* key
# (e.g. point AGENT_claude_CONFIG at a private settings.json). Generic defaults only; no secrets.
#
# Per agent NAME in $AGENTS these vars drive provisioning (scripts/04-provision-subyard.sh):
#   AGENT_<NAME>_CONFIG       host-side default-config template, copied into the yard. Empty = none.
#   AGENT_<NAME>_CONFIG_DEST  where it lands under the dev user's $HOME.
#   AGENT_<NAME>_RULES        optional second artifact (e.g. Codex command rules), same push logic.
#   AGENT_<NAME>_RULES_DEST   where it lands under the dev user's $HOME.
#   AGENT_<NAME>_PERSIST      session/state paths symlinked onto the host-agent-sessions mount,
#                             one "<name under $HOME>:<target>[:file]" per line (":file" = single-file
#                             target, e.g. a db — its parent is made, the path itself is not made).
#
# Why a default config at all: without it the in-yard agent runs in its stock approval mode and
# prompts on every command — even read-only diagnostics — which defeats the point of an isolated
# yard. The defaults below let the agent work freely inside the container (edit/delete, git reset,
# builds/tests, unrestricted network). Publishing git history (push) is gated at the AGENT level —
# Claude via settings.json `ask`, Codex via ~/.codex/rules (decision=prompt) — routed to the
# operator, instead of a yard-wide git shim. See private/tasks/p1-agent-default-permissions.md.
#
# Claude auto-memory lives OUTSIDE ~/.claude (autoMemoryDirectory=~/.claude-memory in the laid-down
# settings.json). Writes under ~/.claude are a protected path: Claude Code checks them before
# permissions.allow is consulted, so no allow rule can pre-approve them, and IDE/remote-attached
# sessions pick their own permission mode (the template's bypassPermissions defaultMode does not
# reach them) — memory writes escalated on every save. Outside ~/.claude they are ordinary writes,
# covered promptless by the plain Edit/Write allow rules in every mode, and the persist line below
# keeps memory on the host store like sessions. Existing yards: run `yard init` (re-provision adds
# the symlink); `yard init --configs` alone only refreshes settings.json.

# Enabled coding agents (drives the lay-down + persist loops).
AGENTS="${AGENTS:-claude codex opencode pi}"

# --- Claude Code -------------------------------------------------------------
AGENT_claude_CONFIG="${AGENT_claude_CONFIG:-$SUBYARD_CONFIG_DIR/agents/claude/settings.json}"
AGENT_claude_CONFIG_DEST="${AGENT_claude_CONFIG_DEST:-.claude/settings.json}"
AGENT_claude_PERSIST="${AGENT_claude_PERSIST:-
.claude/projects:/mnt/host/agent-sessions/claude/projects
.claude-memory:/mnt/host/agent-sessions/claude/memory
}"

# --- Codex -------------------------------------------------------------------
AGENT_codex_CONFIG="${AGENT_codex_CONFIG:-$SUBYARD_CONFIG_DIR/agents/codex/config.toml}"
AGENT_codex_CONFIG_DEST="${AGENT_codex_CONFIG_DEST:-.codex/config.toml}"
AGENT_codex_RULES="${AGENT_codex_RULES:-$SUBYARD_CONFIG_DIR/agents/codex/rules/repo.rules}"
AGENT_codex_RULES_DEST="${AGENT_codex_RULES_DEST:-.codex/rules/repo.rules}"
AGENT_codex_PERSIST="${AGENT_codex_PERSIST:-
.codex/sessions:/mnt/host/agent-sessions/codex/sessions
}"

# --- opencode (no default config yet; sessions still persist) ----------------
AGENT_opencode_CONFIG="${AGENT_opencode_CONFIG:-}"
AGENT_opencode_CONFIG_DEST="${AGENT_opencode_CONFIG_DEST:-}"
AGENT_opencode_PERSIST="${AGENT_opencode_PERSIST:-
.local/share/opencode/storage:/mnt/host/agent-sessions/opencode/storage
.local/share/opencode/opencode.db:/mnt/host/agent-sessions/opencode/opencode.db:file
}"

# --- pi (@earendil-works/pi-coding-agent) ------------------------------------
# pi has NO permission system — it runs with the rights of the process that launched it (the yard
# IS the boundary), so there is nothing to pre-approve per command and no agent-level push gate like
# Claude/Codex (push can only be gated by the yard boundary / your remote auth). All pi state lives
# under ~/.pi/agent (override: PI_CODING_AGENT_DIR). Only sessions are shared to the host store;
# credentials (~/.pi/agent/auth.json) stay per-yard like the other agents. The lone startup friction
# is project-trust — the laid-down settings.json sets defaultProjectTrust=always so pi auto-trusts a
# project's .pi resources in non-interactive runs (-p/json/rpc) instead of ignoring them.
AGENT_pi_CONFIG="${AGENT_pi_CONFIG:-$SUBYARD_CONFIG_DIR/agents/pi/settings.json}"
AGENT_pi_CONFIG_DEST="${AGENT_pi_CONFIG_DEST:-.pi/agent/settings.json}"
AGENT_pi_PERSIST="${AGENT_pi_PERSIST:-
.pi/agent/sessions:/mnt/host/agent-sessions/pi/sessions
}"

# Flat persist list the provisioner/L3/init consume (HOST_LINKS) — composed from the per-agent
# AGENT_*_PERSIST above (was hand-maintained in host.env). host.env no longer sets it, so this
# default wins; an explicit HOST_LINKS in the environment still overrides everything.
HOST_LINKS="${HOST_LINKS:-${AGENT_claude_PERSIST}${AGENT_codex_PERSIST}${AGENT_opencode_PERSIST}${AGENT_pi_PERSIST}}"
