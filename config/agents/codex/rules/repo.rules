# Codex command rules for the yard (laid down at ~/.codex/rules/repo.rules).
# Gate creating and publishing git history at the Codex level — every commit and push prompts
# the operator — rather than a yard-wide git shim. Routine local work (edits, builds, tests,
# git reset) stays free.

prefix_rule(
    pattern = ["git", "commit"],
    decision = "prompt",
    justification = "Creating or amending a commit must be explicitly approved by the operator.",
    match = [
        "git commit",
        "git commit -m msg",
        "git commit --amend",
    ],
)

prefix_rule(
    pattern = ["git", "push"],
    decision = "prompt",
    justification = "Pushing to a remote must be explicitly approved by the operator.",
    match = [
        "git push",
        "git push origin main",
        "git push --force-with-lease",
    ],
)
