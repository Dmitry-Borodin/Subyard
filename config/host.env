# config/host.env — the single home for everything that names a REAL host path:
# host-side state locations and the host→yard file exposure (mounts + symlinks).
#
# Invariant: no host path literal lives in scripts/. They all live here, generic and
# overridable via the environment. Sourced by `load_config` (scripts/lib/config.sh) AFTER
# incus.project.env and subyard.env, so values here may reference those (e.g. HOST_BASE
# follows the Incus project's restricted disk path). Generic defaults only; no secrets.

# Operator home base. Privilege re-entry explicitly preserves SUBYARD_OPERATOR_HOME, so the
# paths below never resolve under root. In the normal non-sudo path it is just $HOME.
: "${SUBYARD_OPERATOR_HOME:=$HOME}"

# Host-side machine-local state, operator-owned — the ONLY place these shapes are named:
#   config/state → $SUBYARD_CONFIG_HOME/projects/<id>.json
#   data/logs    → $SUBYARD_HOME/logs/yard.log   (and exports/, ssh/, storage/ under it)
: "${SUBYARD_CONFIG_HOME:=$SUBYARD_OPERATOR_HOME/.config/subyard}"
: "${SUBYARD_HOME:=$SUBYARD_OPERATOR_HOME/.subyard}"
# Incus dir-pool backing path. Host preflight and installation must check the same filesystem.
: "${STORAGE_PATH:=$SUBYARD_HOME/incus/storage}"

# One host-only encrypted credential ledger per physical owner host. Yard contexts share this
# root but remain distinct consumer/assignment targets; nothing here is mounted into a guest or
# stored in the project checkout. The shared Git repository contains SOPS ciphertext only.
# Identities and local-only records never leave this host. Host identity keys protect the ledger; its payloads are
# staging/QA secret values and config files, often materialized as .env consumers.
: "${SUBYARD_KEYS_ROOT:=$SUBYARD_CONFIG_HOME/keys}"
: "${SUBYARD_KEYS_TOOLS_DIR:=$SUBYARD_CONFIG_HOME/tools}"
: "${SUBYARD_KEYS_SYSTEMD_DIR:=$SUBYARD_OPERATOR_HOME/.config/systemd/user}"

# Exact host-tool pins. Bump a version and both architecture checksums together. `yard init`
# installs these under SUBYARD_KEYS_TOOLS_DIR without replacing system binaries.
: "${SUBYARD_AGE_VERSION:=1.3.1}"
: "${SUBYARD_AGE_SHA256_AMD64:=bdc69c09cbdd6cf8b1f333d372a1f58247b3a33146406333e30c0f26e8f51377}"
: "${SUBYARD_AGE_SHA256_ARM64:=c6878a324421b69e3e20b00ba17c04bc5c6dab0030cfe55bf8f68fa8d9e9093a}"
: "${SUBYARD_SOPS_VERSION:=3.13.2}"
: "${SUBYARD_SOPS_SHA256_AMD64:=154dfe4cd70554bdd82b98e4cd4acf191d43d01ead6f00a73477aa44c4ac42ef}"
: "${SUBYARD_SOPS_SHA256_ARM64:=78abf2e15c86250a1553ae6f53aba96be6b2a8126f160b1534959add3467ad76}"

# Root-owned host boot reconciler. `yard init` copies immutable runtime files here instead of
# executing the operator-writable checkout as root at boot. Override for packaging/tests.
: "${SUBYARD_POWER_LIBEXEC_DIR:=/usr/local/libexec/subyard}"
: "${SUBYARD_POWER_RECONCILER_PATH:=$SUBYARD_POWER_LIBEXEC_DIR/yard-boot-reconcile}"
: "${SUBYARD_POWER_LIB_PATH:=$SUBYARD_POWER_LIBEXEC_DIR/lib-power.sh}"
: "${SUBYARD_POWER_UNIT_PATH:=/etc/systemd/system/subyard-power-reconcile.service}"

# Single prefix for Subyard-managed personal-data mounts. It matches RESTRICTED_DISK_PATHS;
# scripts/05 and security-lint enforce it because Incus's disk-source allowlist conflicts with
# idmapped `shift=true`. Explicit `yard bind` sources are operator-selected and may live elsewhere.
: "${HOST_BASE:=${RESTRICTED_DISK_PATHS:-/srv/subyard}}"

# Default host mounts exposed into the yard — what + how. One per line:
#   "<device/subdir under HOST_BASE>:<path in yard>:<ro|rw>:<dir-mode>"
# `yard init` reconciles to this list: attaches missing, re-attaches changed, and
# detaches host-* mounts no longer listed (the yard is rebuildable — warned, never the
# host). Device/subdir names are conventionally 'host-*'. A project can ask for more
# yard-level mounts via YARD_MOUNTS in its profile.
#
# host-agent-sessions (default on): host store where coding-agent sessions persist across yard
# resets (creds are not shared). Remove the line to stop.
HOST_MOUNTS="${HOST_MOUNTS:-
host-secrets:/mnt/host/secrets:ro:0700
host-memory:/mnt/host/memory:rw:0770
host-devcontainers:/mnt/host/devcontainers:ro:0755
host-agent-sessions:/mnt/host/agent-sessions:rw:0700
}"

# The operator's global agent instructions, copied into the yard at provision (not mounts or
# symlinks) so in-yard agents inherit the same working agreements. Empty either value to skip it.
HOST_CLAUDE_MD="${HOST_CLAUDE_MD:-$SUBYARD_OPERATOR_HOME/.claude/CLAUDE.md}"
HOST_CODEX_AGENTS_MD="${HOST_CODEX_AGENTS_MD:-$SUBYARD_OPERATOR_HOME/.codex/AGENTS.md}"
