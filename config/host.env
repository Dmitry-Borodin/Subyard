# config/host.env — the single home for everything that names a REAL host path:
# host-side state locations and the host→yard file exposure (mounts + symlinks).
#
# Invariant: no host path literal lives in scripts/. They all live here, generic and
# overridable via the environment. Sourced by `load_config` (scripts/lib.sh) AFTER
# incus.project.env and subyard.env, so values here may reference those (e.g. HOST_BASE
# follows the Incus project's restricted disk path). Generic defaults only; no secrets.

# Operator home base. Scripts that self-elevate (sudo) pre-set SUBYARD_OPERATOR_HOME to
# the real operator's home BEFORE calling load_config, so the paths below don't resolve
# under root. In the normal (non-sudo) path it is just $HOME.
: "${SUBYARD_OPERATOR_HOME:=$HOME}"

# Host-side machine-local state, operator-owned — the ONLY place these shapes are named:
#   config/state → $SUBYARD_CONFIG_HOME/projects/<id>.json
#   data/logs    → $SUBYARD_HOME/logs/yard.log   (and exports/, ssh/, storage/ under it)
: "${SUBYARD_CONFIG_HOME:=$SUBYARD_OPERATOR_HOME/.config/subyard}"
: "${SUBYARD_HOME:=$SUBYARD_OPERATOR_HOME/.subyard}"

# Single allowed host-mount prefix exposed into the yard. Matches the Incus project's
# restricted.devices.disk.paths (RESTRICTED_DISK_PATHS, config/incus.project.env) so the
# two can never drift. The host exposes ONLY this directory — never $HOME/.ssh/etc.
: "${HOST_BASE:=${RESTRICTED_DISK_PATHS:-/srv/subyard}}"

# Default host mounts exposed into the yard — what + how. One per line:
#   "<device/subdir under HOST_BASE>:<path in yard>:<ro|rw>:<dir-mode>"
# `yard init` reconciles to this list: attaches missing, re-attaches changed, and
# detaches host-* mounts no longer listed (the yard is rebuildable — warned, never the
# host). Device/subdir names are conventionally 'host-*'. A project can ask for more
# yard-level mounts via YARD_MOUNTS in its profile.
#
# host-agent-sessions (default on): shares coding-agent session transcripts host<->yard so
# host-side token stats (ccusage, /cost) see the yard's usage. HOST_LINKS below points the
# dev user's ~/.claude/projects and ~/.codex/sessions at it. Credentials are NOT shared —
# they live per-yard in the yard rootfs; only sessions go here. Remove the line to stop.
HOST_MOUNTS="${HOST_MOUNTS:-
host-secrets:/mnt/host/secrets:ro:0700
host-memory:/mnt/host/memory:rw:0770
host-devcontainers:/mnt/host/devcontainers:ro:0755
host-agent-sessions:/mnt/host/agent-sessions:rw:0700
}"

# Host-backed symlinks in the dev user's $HOME, created during provisioning. One per line:
# "<name under dev $HOME>:<target path in yard>". Used for sessions only — point
# ~/.claude/projects and ~/.codex/sessions at the host-agent-sessions mount; do NOT link
# ~/.claude or ~/.codex wholesale (credentials stay in the yard rootfs). Provisioning makes
# the link's parent, creates the target, skips an entry whose mount isn't attached, and
# never clobbers a real directory that already holds data.
HOST_LINKS="${HOST_LINKS:-
.claude/projects:/mnt/host/agent-sessions/claude/projects
.codex/sessions:/mnt/host/agent-sessions/codex/sessions
}"

# The operator's global agent instructions, copied into the yard at provision (not a
# mount, not symlinked) so the in-yard agent uses your CLAUDE.md without rewriting it.
# Empty to skip.
HOST_CLAUDE_MD="${HOST_CLAUDE_MD:-$SUBYARD_OPERATOR_HOME/.claude/CLAUDE.md}"
