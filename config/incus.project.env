# config/incus.project.env — Incus project settings for the Subyard yard (Phase 1).
#
# Sourced by scripts/02-create-project.sh. Values here are generic defaults
# (no host paths, no secrets). Override any of them via the environment.

# Name of the isolated Incus project that holds the yard.
INCUS_PROJECT=agent-dev

# Host path prefix that disk devices in this project may bind from
# (restricted.devices.disk.paths). Subyard's single allowed host-mount prefix
# — the §18 invariant: the host exposes only this directory to the yard.
RESTRICTED_DISK_PATHS=/srv/subyard
