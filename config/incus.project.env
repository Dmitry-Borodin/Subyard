# config/incus.project.env — Incus project settings for the Subyard yard (Phase 1).
#
# Sourced by scripts/02-create-project.sh. Values here are generic defaults
# (no host paths, no secrets). Override any of them via the environment.

# Name of the isolated Incus project (namespace) that holds the yard instance.
# This is the Incus project, NOT your code project — see the glossary. A named yard
# derives subyard-<name> in scripts/lib/registry.sh before this file loads.
: "${INCUS_PROJECT:=subyard}"

# Host path prefix for Subyard-managed personal-data mounts. Incus's
# restricted.devices.disk.paths cannot be enabled together with the idmapped `shift=true`
# mounts Subyard needs, so scripts/05 + security-lint enforce it for Subyard-managed mounts.
# Explicit project binds are operator-selected and may intentionally come from elsewhere.
# A named yard derives /srv/subyard-<name> (HOST_BASE follows it in host.env).
: "${RESTRICTED_DISK_PATHS:=/srv/subyard}"

# Managed bridge the yard attaches to (project nic + host firewall rule).
: "${INCUS_BRIDGE:=incusbr0}"
