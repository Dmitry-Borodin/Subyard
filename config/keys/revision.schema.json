{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://subyard.example/schema/keys/revision-v1.json",
  "title": "Subyard encrypted credential revision v1",
  "type": "object",
  "required": [
    "schemaVersion", "credentialId", "revisionId", "label", "kind", "zone", "scope", "consumer",
    "syncable", "exclusive", "authorityHost", "assignedYard", "assignmentEpoch", "actorId",
    "actorCounter", "parents", "timestamp", "state", "recipientActors", "payload", "sops"
  ],
  "properties": {
    "schemaVersion": {"const": 1},
    "credentialId": {"type": "string", "pattern": "^cred-[a-f0-9]{32}$"},
    "revisionId": {"type": "string", "pattern": "^[A-Za-z0-9._-]+-[0-9]{12}-[a-f0-9]{8}$"},
    "label": {"type": "string", "minLength": 1, "maxLength": 128},
    "kind": {"type": "string", "pattern": "^[A-Za-z0-9._-]+$"},
    "zone": {"type": "string", "pattern": "^[A-Za-z0-9._-]+$"},
    "scope": {"const": "staging"},
    "consumer": {"enum": ["none", "staging-env", "qa-secrets", "qa-pool"]},
    "syncable": {"type": "boolean"},
    "exclusive": {"type": "boolean"},
    "authorityHost": {"type": "string", "pattern": "^$|^[A-Za-z0-9._-]+$"},
    "assignedYard": {"type": "string", "pattern": "^$|^[A-Za-z0-9._-]+/[a-z0-9][a-z0-9_-]*$"},
    "assignmentEpoch": {"type": "integer", "minimum": 0},
    "actorId": {"type": "string", "pattern": "^[A-Za-z0-9._-]+$"},
    "actorCounter": {"type": "integer", "minimum": 1},
    "parents": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "timestamp": {"type": "string", "format": "date-time"},
    "state": {"enum": ["active", "revoked", "tombstone"]},
    "recipientActors": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
    "payload": {"type": "string", "pattern": "^ENC\\["},
    "sops": {"type": "object", "required": ["age", "mac"]}
  },
  "additionalProperties": false
}
