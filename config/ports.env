# config/ports.env — host-side loopback ports Subyard exposes via Incus proxy devices.
#
# Generic defaults only; no secrets. Override any value via the environment or the
# machine-local overlay ($HOME/.subyard/config.env). Sourced by load_config
# (scripts/lib.sh) with the other config/*.env layers.
#
# Invariant: every port here binds 127.0.0.1 ONLY (loopback). Nothing Subyard exposes
# is reachable on the LAN — host traffic reaches the in-yard service through the proxy
# device, never the other way round.

# --- Android emulator adb bridge (P1) ----------------------------------------------
# The in-yard emulator (config/profiles/android/emulator-run.sh) listens on the yard's
# loopback: the first AVD uses console :5554 (even) and adb :5555 (odd). `yard emu up`
# adds an Incus proxy device  host 127.0.0.1:$ADB_PROXY_PORT -> yard 127.0.0.1:$ADB_EMULATOR_PORT
# so the host can `adb connect 127.0.0.1:$ADB_PROXY_PORT` and run scrcpy against it.
# One emulator here (P1); P2 (pool/lease) generalizes this to a per-instance port range.
: "${ADB_EMULATOR_PORT:=5555}"
: "${ADB_PROXY_PORT:=15555}"

# Optional: the emulator *console* port (even; gated by ~/.emulator_console_auth_token).
# Usually NOT needed — adb is enough for instrumented tests and scrcpy. Set
# ADB_CONSOLE_PROXY_PORT (e.g. 15554) to have `yard emu up` bridge it too.
: "${ADB_CONSOLE_EMULATOR_PORT:=5554}"
: "${ADB_CONSOLE_PROXY_PORT:=}"
