# Profile: openclaw — dependency profile for the OpenClaw codebase (Node + Python).
#
# A profile is the only place that knows about a toolchain. The generic core
# reads these values to specialize an agent machine; it knows nothing about
# what they mean. Copy android.env to create a new profile.
#
# This profile carries what an agent needs to BUILD the codebase and RUN its
# tests, up to the full e2e matrix. The heavy parts (a headless browser, nested
# rootless Docker) are OPTIONAL and off by default — see OPTIONAL_FEATURES — so a
# plain dev machine stays lean while the full surface stays available on demand.
#
# Out of scope: running the gateway live (provider keys, a chat bot, end-to-end
# approvals). That is a separate opt-in stack — no credentials belong here.

PROFILE_NAME=openclaw

# Base image for this profile's agent machines (overrides the core default).
# A self-contained toolchain image (Node + pnpm + a Python venv) sits on top.
BASE_IMAGE=ubuntu:24.04

# Shared, writable dependency caches (created under the yard's /srv).
# Agents fill these themselves; there is no read-only seeder.
CACHES="/srv/cache/pnpm /srv/cache/pip /srv/cache/npm"

# Environment exported into the agent machines — point the package managers at
# the shared caches above (pnpm honors the npm_config_* keys).
PIP_CACHE_DIR=/srv/cache/pip
npm_config_cache=/srv/cache/npm
npm_config_store_dir=/srv/cache/pnpm

# Devices this profile requires from the core (space-separated keys).
# None by default: no KVM. (The sandbox_tests feature below needs container
# nesting, which is a yard-level setting, not a per-profile device.)
DEVICES=""

# Optional capabilities — available, not hardcoded. Off by default; list the
# features a machine needs (space-separated). Each pulls heavier dependencies
# and/or wants a more capable yard. A plain build plus unit/integration tests
# needs none of them; the full e2e run wants both:
#
#   OPTIONAL_FEATURES="browser_tests sandbox_tests"
#
#   browser_tests  Headless browser (Playwright + Chromium and its system libs)
#                  for the browser/voice extensions and the full vitest matrix.
#                  Browsers cache in PLAYWRIGHT_BROWSERS_PATH (shared, once).
#   sandbox_tests  Rootless Docker + bubblewrap for the sandbox-isolation tests
#                  and for building the coding-sandbox image. Needs container
#                  nesting (a yard with Docker + security.nesting, or
#                  INSTANCE_TYPE=vm for the full, clean run).
OPTIONAL_FEATURES=""

# Shared browser cache for the browser_tests feature (download once, reuse).
PLAYWRIGHT_BROWSERS_PATH=/srv/cache/playwright

# Toolchain versions (example pins; adjust per project).
NODE_VERSION=22.22.2
PNPM_VERSION=11.1.0
PYTHON_VERSION=3.11
VITEST_VERSION=4.1.5
TYPESCRIPT_VERSION=6.0.3
