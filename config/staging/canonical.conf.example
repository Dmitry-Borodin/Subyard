# Copy to ~/.config/subyard/overrides/host/staging/<zone>.conf.
# A zone is a SHARED live-gateway environment, identified by its name — not by a dev project.
# `canonical` is the persistent baseline zone built from `master`. Secrets never go here; the
# zone's credential VALUES live inside the runner (see <zone>.env and `yard staging shell`).

# Which dependency profile supplies the toolchain image (config/profiles/<PROFILE>/).
PROFILE=openclaw

# Toolchain image: a Dockerfile path INSIDE the source tree that builds the runner's toolchain
# (node/pnpm/python). For a live-bind run it is built from the AGENT's tree => the agent's
# toolchain version. Context defaults to the Dockerfile's dir; tag to subyard-staging-<zone>.
# Empty => run the profile BASE_IMAGE directly (no toolchain — the gateway won't build/run).
#   IMAGE_DOCKERFILE=docker/<your-devcontainer>.Dockerfile
# IMAGE_DOCKERFILE=""

# Where the gateway's source tree comes from. Two ways:
#   * SOURCE_BIND set  -> bind that yard path read/write as /workspace. MVP live-bind: point it at an
#                         agent's workspace (e.g. /srv/workspaces/<id>) to run their UNCOMMITTED code
#                         with no commit (edits propagate into the running stage by design). Or per-run
#                         via CLI: `yard staging up <zone> --source /srv/workspaces/<id>`.
#   * SOURCE_BIND empty -> the zone's own /srv/staging/<zone>/src, which you populate from `master`
#                         (clone the project into it once; update with git fetch/checkout).
# SOURCE_BIND=""

# Persistent credentials store INSIDE the runner — a one-time manual provider login (Codex) lands
# here and survives box recreate (backed by /srv/staging/<zone>/creds). Set to the runner's creds
# dir; if creds already live under VASILY_HOME (persisted), leave empty. Find the path via
# `yard staging shell <zone>` after the first login.
# CREDS_DEST=""

# Command the runner launches as the gateway (cwd = /workspace). Default below.
# GATEWAY_CMD="scripts/vasily gateway run"

# Rebuild command run in the runner (cwd /workspace) BEFORE the gateway launches, so `restart`
# (and in-yard `sy-stage restart`) picks up the agent's live edits. Empty => no rebuild.
#   BUILD_CMD="VASILY_OPENCLAW_ALLOW_LIVE_BUILD=1 scripts/vasily openclaw-source build"
# BUILD_CMD=""

# Bot-identity lease key (the scarce resource). Zones sharing one test bot MUST share this key
# so only one polls at a time. Default `bot` = the single shared test bot.
# BOT_LEASE_KEY=bot

# Lease TTL in seconds (heartbeat renews at TTL/3). Keep > the gateway's long-poll timeout.
# LEASE_TTL=45
