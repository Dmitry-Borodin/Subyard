# Import with `yard keys`, then materialize as generated/staging/<zone>.env. This is the
# NON-CRED staging contract: a marker + optional gateway-command override. Credential VALUES
# (the staging bot token, the staging model auth) do NOT go here — they live inside the
# runner's persistent data root, pasted once by the operator:
#   yard staging shell <zone>
#   # inside the box, $VASILY_HOME points at the zone's staging data root:
#   #   - put the STAGING telegram bot token in $VASILY_HOME/openclaw/openclaw.json
#   #       channels.telegram.tokenFile  (preferred: a 0600 file)  or  .botToken
#   #   - mark the config staging:  "_subyardStaging": true
#   #   - log in the STAGING model provider once (creds persist under .../creds)
#
# It is staged into the yard and mounted READ-ONLY at /run/subyard/staging.env (never -e).

# Required (unless the config carries "_subyardStaging": true): mark this runner as staging so
# the prod-guard allows it to start.
SUBYARD_STAGING=1

# Optional: override the gateway command for this zone (else config's GATEWAY_CMD / the default).
# STAGING_GATEWAY_CMD="scripts/vasily gateway run"

# Optional: staging MODEL key for a LIVE model move (the `sy-stage test` lane). A static
# host-config secret (e.g. a spend-capped Anthropic API key) injected into the test subprocess
# ONLY for that run (never the runner's persistent env, never logged): `sy-stage test -- <cmd>`
# exports it as ANTHROPIC_API_KEY + STAGING_MODEL_KEY and sets SUBYARD_LIVE_MODEL=1; with no key
# here, SUBYARD_LIVE_MODEL stays unset so live model tests SKIP cleanly. This is the "simple path,
# no broker" track. (The Codex-subscription path is a one-time manual login in the runner instead
# — persistent creds volume, CREDS_DEST — not a key here.)
# STAGING_MODEL_KEY=

# Reminder (enforced by the guard, not read from here): record the PROD bot-token fingerprint(s)
# so the guard refuses them —
#   printf '%s' "<PROD_BOT_TOKEN>" | sha256sum    # hash only, never the token
#   echo "<that-hash>" >> ~/.config/subyard/overrides/host/prod-fingerprints
