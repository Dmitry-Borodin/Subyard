# config/subyard.env — yard instance settings (Phase 2).
#
# Sourced by scripts/03-create-subyard.sh and scripts/05-mount-host-paths.sh.
# Generic defaults only; override any value via the environment.

# Incus instance (the yard itself).
INSTANCE_NAME=yard

# container | vm  — system container is the default; vm is a
# parameter (stronger boundary, nested virt) that installs qemu lazily.
INSTANCE_TYPE=container

# Yard OS base image (Debian 13 Trixie default, Ubuntu fallback). This is the yard
# userspace; the devcontainer base is per-profile.
BASE_IMAGE=images:debian/13
BASE_IMAGE_FALLBACK=images:ubuntu/24.04

# Resource limits — uncomment to opt in.
# LIMITS_CPU=8
# LIMITS_MEMORY=24GiB

# Persistent /srv lives on a custom volume that survives instance rebuild.
SRV_POOL=default
SRV_VOLUME=yard-srv

# Single allowed host-mount prefix (matches the project's
# restricted.devices.disk.paths). Created by 05-mount-host-paths.sh.
HOST_BASE=/srv/subyard

# Default host mounts exposed into the yard — what + how. One per line:
#   "<device/subdir under HOST_BASE>:<path in yard>:<ro|rw>:<dir-mode>"
# The host exposes only these, all under HOST_BASE. `yard setup` reconciles to this
# list: attaches missing, re-attaches changed, detaches host-* mounts dropped from it
# (yard only, with a warning). Names are conventionally 'host-*'; a project can request
# more yard-level mounts via YARD_MOUNTS in its profile.
#
# host-agent (default on): coding-agent state (Claude/Codex credentials + session/
# usage) shared host<->yard so subscription usage is one pool. Lives in
# $HOST_BASE/host-agent/{claude,codex}; provisioning symlinks the dev user's
# ~/.claude and ~/.codex to /mnt/host/agent. rw because the OAuth token refreshes.
# To share stats with a host-side agent too, point the host's ~/.claude / ~/.codex
# at $HOST_BASE/host-agent/* once. Remove the line to opt out.
HOST_MOUNTS="
host-secrets:/mnt/host/secrets:ro:0700
host-memory:/mnt/host/memory:rw:0770
host-devcontainers:/mnt/host/devcontainers:ro:0755
host-agent:/mnt/host/agent:rw:0700
"

# UID/GID shifting for host mounts: shift (idmapped) | acl (fallback).
SHIFT_MODE=shift

# Forward the host ssh-agent into the yard by default, so in-yard git over SSH uses
# keys held by your agent (only the socket is forwarded). Set 0 to opt out.
# (Consumed by 07-ssh-access.sh / yard-ctl.sh.)
FORWARD_SSH_AGENT=1

# Unprivileged in-yard user created during provisioning (Phase 3).
DEV_USER=dev

# UID of the in-yard 'dev' user; host-mount dirs are chowned to it so shift maps
# host<->yard ownership 1:1. Set to your host uid for sudo-free /srv/subyard management.
DEV_UID=1000

# SSH into the yard (proxy device + ~/.ssh Host alias). SSH_HOST is also the
# ssh alias yard sync/bind/code write into project state.
SSH_HOST=yard
SSH_PORT=2222
