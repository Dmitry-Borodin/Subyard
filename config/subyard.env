# config/subyard.env — yard instance settings (Phase 2).
#
# Sourced by scripts/03-create-subyard.sh and scripts/05-mount-host-paths.sh.
# Generic defaults only — NO host paths (those live in config/host.env), no secrets.
# Override any value via the environment.

# Incus instance (the yard itself). A named yard (yard -Y <name>) derives yard-<name> in
# scripts/lib/registry.sh before this file loads; the := below only supplies the default-yard value.
: "${INSTANCE_NAME:=yard}"

# container | vm  — system container is the default; vm is a
# parameter (stronger boundary, nested virt) that installs qemu lazily.
: "${INSTANCE_TYPE:=container}"

# Opt-in test lab: allow the L1 container yard to run exactly two disposable
# Incus VMs. Enabling this widens the L0/L1 device boundary: the host must pass
# KVM/vsock and allow device-cgroup BPF interception. Keep it off for normal
# yards; use only on a trusted, resource-limited test yard.
: "${NESTED_E2E_VMS:=0}"
: "${E2E_VM_IMAGE:=images:debian/13/cloud}"
: "${E2E_VM_CPU:=2}"
: "${E2E_VM_MEMORY:=4GiB}"
: "${E2E_VM_DISK:=30GiB}"
: "${E2E_VM_TTL_MINUTES:=240}"
: "${E2E_VM_BOOT_TIMEOUT:=300}"

# Yard OS base image (Debian 13 Trixie default, Ubuntu fallback). This is the yard
# userspace; the devcontainer base is per-profile.
: "${BASE_IMAGE:=images:debian/13}"
: "${BASE_IMAGE_FALLBACK:=images:ubuntu/24.04}"

# Resource limits — uncomment to opt in.
# LIMITS_CPU=8
# LIMITS_MEMORY=24GiB

# Persistent /srv lives on a custom volume that survives instance rebuild.
# SRV_VOLUME derives yard-srv-<name> for a named yard (scripts/lib/registry.sh).
: "${SRV_POOL:=default}"
: "${SRV_VOLUME:=yard-srv}"

# Host paths and the host→yard file exposure (HOST_BASE, HOST_MOUNTS, HOST_LINKS)
# live in config/host.env — the single place real host paths are named.

# UID/GID shifting for host mounts: shift (idmapped) | acl (fallback).
: "${SHIFT_MODE:=shift}"

# Forward the host ssh-agent into the yard by default, so in-yard git over SSH uses
# keys held by your agent (only the socket is forwarded). Set 0 to opt out.
# (Consumed by 07-ssh-access.sh / yard-ctl.sh.)
: "${FORWARD_SSH_AGENT:=1}"

# Unprivileged in-yard user created during provisioning (Phase 3).
: "${DEV_USER:=dev}"

# UID of the in-yard 'dev' user; host-mount dirs are chowned to it so shift maps
# host<->yard ownership 1:1. Set to your host uid for sudo-free /srv/subyard management.
: "${DEV_UID:=1000}"

# Passwordless sudo for the in-yard 'dev' user. Default OFF in the public config; enable it
# in the private overlay (private/config.env: DEV_SUDO=1) or via the environment. When on,
# the coding agent — and you via `yard shell` — can make root changes in the yard; safe in
# our model (dev is already ~root-in-yard via the docker group, yard is unprivileged).
# Reconciled: flipping to 0 removes the grant on the next provision. (Consumed by 04.)
: "${DEV_SUDO:=0}"

# SSH into the yard (proxy device + ~/.ssh Host alias). SSH_HOST is also the
# ssh alias yard sync/bind/code write into project state. A named yard derives
# SSH_HOST=yard-<name> (scripts/lib/registry.sh) and MUST declare its own SSH_PORT in the yard
# env file — the one value we cannot derive without risking a host-port collision.
: "${SSH_HOST:=yard}"
: "${SSH_PORT:=2222}"
