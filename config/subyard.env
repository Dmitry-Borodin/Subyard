# config/subyard.env — yard instance settings (Phase 2).
#
# Sourced by scripts/03-create-subyard.sh and scripts/05-mount-host-paths.sh.
# Generic defaults only (no host paths beyond the fixed /srv/subyard prefix, no
# secrets). Override any value via the environment.

# Incus instance (the yard itself).
INSTANCE_NAME=yard

# container | vm  — system container is the default; vm is a
# parameter (stronger boundary, nested virt) that installs qemu lazily.
INSTANCE_TYPE=container

# Yard OS base image (Debian 13 Trixie default, Ubuntu fallback).
# This is the yard userspace, NOT the devcontainer base (that is per-profile).
BASE_IMAGE=images:debian/13
BASE_IMAGE_FALLBACK=images:ubuntu/24.04

# Resource limits — NOT set by default. Uncomment to opt in.
# LIMITS_CPU=8
# LIMITS_MEMORY=24GiB

# Persistent /srv lives on a custom volume that survives instance rebuild.
SRV_POOL=default
SRV_VOLUME=yard-srv

# Single allowed host-mount prefix (matches the project's
# restricted.devices.disk.paths). Created by 05-mount-host-paths.sh.
HOST_BASE=/srv/subyard

# UID/GID shifting for host mounts: shift (idmapped) | acl (fallback).
SHIFT_MODE=shift

# Unprivileged in-yard user created during provisioning (Phase 3).
DEV_USER=dev
