# config/yards/e2e-yard.env.example — dormant public template for the trusted nested-VM
# acceptance lane. This file is not loaded from config/yards/. Explicitly copy it to one of:
#
#   private/yards/e2e-yard.env
#   ~/.config/subyard/yards/e2e-yard.env
#
# Copying it into a registry opts yard-e2e-yard into the wider KVM/vsock/BPF boundary documented
# in docs/test-vms.md. Review that boundary first. Use a different unique port when 2223 is already
# assigned to another yard on the host.

SSH_PORT=2223

# The L1 yard stays a container. Its inner Incus daemon creates the two actual VMs.
INSTANCE_TYPE=container
NESTED_E2E_VMS=1

# Reproducible defaults for e2e-vm-1 and e2e-vm-2.
E2E_VM_IMAGE=images:debian/13/cloud
E2E_VM_CPU=2
E2E_VM_MEMORY=4GiB
# Leaves at least 20 GiB free after the guest OS for Subyard's own host preflight.
E2E_VM_DISK=30GiB
E2E_VM_TTL_MINUTES=240
E2E_VM_BOOT_TIMEOUT=300
