# Copy to ~/.config/subyard/yards/<name>/config.env.
# Source checkouts may instead use private/yards/<name>.env.

# Required: unique host loopback port.
SSH_PORT=2223

# Optional public yard template.
# YARD_TEMPLATE=test-vms

# Optional project-profile allowlist. Unset means all profiles.
# YARD_PROFILES="openclaw"

# Optional stronger yard boundary.
# INSTANCE_TYPE=vm

# Optional resource limits.
# LIMITS_CPU=8
# LIMITS_MEMORY=24GiB

# Optional agent config selection.
# AGENTS="claude codex pi"
