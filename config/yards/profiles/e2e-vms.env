# Public reusable settings for the trusted nested-VM acceptance lane.
# This file is dormant. A private or machine-local yard must explicitly select
# YARD_TEMPLATE=e2e-vms before any of these settings are loaded.

# The L1 yard stays a container. Its inner Incus daemon creates the two actual VMs.
INSTANCE_TYPE=container
NESTED_E2E_VMS=1

# Reproducible defaults for e2e-vm-1 and e2e-vm-2.
E2E_VM_IMAGE=images:debian/13/cloud
E2E_VM_CPU=2
E2E_VM_MEMORY=4GiB
E2E_VM_DISK=10GiB
E2E_VM_TTL_MINUTES=240
E2E_VM_BOOT_TIMEOUT=300
