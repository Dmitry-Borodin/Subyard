# Dormant public profile; enable it explicitly with YARD_TEMPLATE=e2e-vms.
# L1 is a privileged VM host, not an agent workspace.

# Inner Incus creates the VMs; L1 remains a container.
INSTANCE_TYPE=container
NESTED_E2E_VMS=1
FORWARD_SSH_AGENT=0

# Defaults for e2e-vm-1 and e2e-vm-2.
E2E_VM_IMAGE=images:debian/13/cloud
E2E_VM_CPU=2
E2E_VM_MEMORY=4GiB
E2E_VM_DISK=10GiB
E2E_VM_TTL_MINUTES=240
E2E_VM_BOOT_TIMEOUT=300

# Agent ingress requires a separate local enrollment request.
