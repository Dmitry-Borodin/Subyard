#!/usr/bin/env bash
set -euo pipefail

case "${1:-}:${2:-}" in
  info:*)
    exit 0
    ;;
  list:*)
    printf 'RUNNING\n'
    ;;
  file:push)
    : "${MOCK_YARD_ROOT:?MOCK_YARD_ROOT is required}"
    source_file="$3"
    yard_path="$4"
    relative="${yard_path#*/}"
    destination="$MOCK_YARD_ROOT/$relative"
    mkdir -p "$(dirname "$destination")"
    cp "$source_file" "$destination"
    ;;
  *)
    printf 'unexpected mocked incus call: %s\n' "$*" >&2
    exit 1
    ;;
esac
